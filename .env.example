# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Easiest free option: https://neon.tech (sign up, create project, copy URL)
DATABASE_URL="postgresql://user:password@host:5432/content_tracker?sslmode=require"

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# Takes ~5 minutes. Just needs a Google account (Gmail is fine).
# 1. Go to https://console.cloud.google.com
# 2. Create a new project (or use any existing one)
# 3. Search for "YouTube Data API v3" → Enable
# 4. Go to Credentials → Create Credentials → API Key
# 5. Copy it here. Free quota = 10,000 units/day, which is plenty.
YOUTUBE_API_KEY=""

# ── TikTok / Instagram ────────────────────────────────────────────────────────
# NO API KEYS NEEDED.
# TikTok and Instagram are tracked by scraping their public web interfaces.
# Just add a creator by their @handle or profile URL — no credentials required.

# ── Vercel Cron Protection ────────────────────────────────────────────────────
# Protects your cron endpoints from being triggered by anyone else.
# Generate with: openssl rand -hex 32
CRON_SECRET=""
