# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (Neon / Supabase / Railway / any Postgres host)
DATABASE_URL="postgresql://user:password@host:5432/content_tracker?sslmode=require"

# ── YouTube Data API v3 ────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=""

# ── TikTok Research API ───────────────────────────────────────────────────────
# Apply for access at: https://developers.tiktok.com/products/research-api
# Requires approval — once approved, create an app and copy the credentials.
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# ── Instagram Graph API ───────────────────────────────────────────────────────
# Option A (own account only): generate a long-lived User Access Token at
#   https://developers.facebook.com > your app > Instagram Basic Display
# Option B (competitor tracking): also add INSTAGRAM_BUSINESS_ACCOUNT_ID.
#   See src/lib/platforms/instagram.ts for the full setup guide.
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""  # optional, for Business Discovery

# ── Vercel Cron Protection ────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=""
